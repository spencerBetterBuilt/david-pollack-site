---
import BaseLayout from '../layouts/BaseLayout.astro';
import socialLinks from '../data/socialLinks.json';
---

<BaseLayout
  title="Media — David Pollack Podcast, Videos & Social"
  description="Watch and listen to David Pollack. College football analysis, faith and family conversations, and motivational content across YouTube, Spotify, Apple Podcasts, Instagram, and more."
  canonicalUrl="https://davidpollack.com/media/"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-grid" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-content">
        <div class="section-tag">Media</div>
        <h1 class="page-hero-title">PODCAST,<br>VIDEO <span>&</span> MORE</h1>
        <p class="page-hero-subtitle">David across every platform — analysis, conversations, and content worth your time.</p>
      </div>
    </div>
  </section>

  <!-- PODCAST -->
  <section class="podcast-section">
    <div class="container">
      <div class="section-tag reveal">Podcast</div>
      <h2 class="podcast-title reveal reveal-delay-1">SEE BALL. GET BALL.</h2>
      <p class="podcast-desc reveal reveal-delay-2">
        College football insights from a former All-American and ESPN analyst. David breaks down the game the way only someone who's played and broadcast it at the highest level can.
      </p>
      <div class="podcast-platforms reveal reveal-delay-3">
        <a href={socialLinks.spotify} target="_blank" rel="noopener noreferrer" class="platform-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path fill="white" d="M8 11.5c2.5-1 5.5-.5 7 1M8 14c2-0.8 4.5-.4 6 .8M9 9c3-1.2 6.5-.5 8.5 1.5"/></svg>
          Spotify
        </a>
        <a href={socialLinks.apple} target="_blank" rel="noopener noreferrer" class="platform-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
          Apple Podcasts
        </a>
        <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="platform-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.6C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
          YouTube
        </a>
      </div>
      <div class="podcast-embed reveal">
        <iframe
          style="border-radius:12px"
          src="https://open.spotify.com/embed/show/1t835E1wS2wOc9dp85EeJV?utm_source=generator"
          width="100%"
          height="352"
          frameborder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="See Ball Get Ball podcast on Spotify"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- SOCIAL LINKS -->
  <section class="social-section">
    <div class="container">
      <div class="section-tag reveal">Follow Along</div>
      <h2 class="social-title reveal reveal-delay-1">FIND DAVID EVERYWHERE</h2>
      <div class="social-grid">
        <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="social-card reveal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          <div>
            <div class="social-card-name">Instagram</div>
            <div class="social-card-handle">@davidpollack47</div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="social-card-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="social-card reveal reveal-delay-1">
          <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.6C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
          <div>
            <div class="social-card-name">YouTube</div>
            <div class="social-card-handle">@DavidPollack47</div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="social-card-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="social-card reveal reveal-delay-2">
          <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          <div>
            <div class="social-card-name">Facebook</div>
            <div class="social-card-handle">davidpollack47</div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="social-card-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={socialLinks.twitter} target="_blank" rel="noopener noreferrer" class="social-card reveal reveal-delay-3">
          <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <div>
            <div class="social-card-name">X / Twitter</div>
            <div class="social-card-handle">@davidpollack47</div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="social-card-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={socialLinks.tiktok} target="_blank" rel="noopener noreferrer" class="social-card reveal reveal-delay-4">
          <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.78a4.85 4.85 0 0 1-1.01-.09z"/></svg>
          <div>
            <div class="social-card-name">TikTok</div>
            <div class="social-card-handle">@davidpollack47</div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="social-card-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    background: var(--black);
    padding: clamp(140px, 15vw, 180px) 0 clamp(80px, 8vw, 100px);
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 60% 40%, rgba(200,16,46,0.12) 0%, transparent 55%),
      linear-gradient(135deg, var(--black) 0%, var(--charcoal) 100%);
  }
  .page-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .page-hero-content { position: relative; z-index: 2; }
  .page-hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  .page-hero-title span { color: var(--red); }
  .page-hero-subtitle {
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    max-width: 500px;
  }

  .podcast-section { padding: clamp(80px, 10vw, 120px) 0; }
  .podcast-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .podcast-desc {
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    color: #555;
    font-weight: 300;
    line-height: 1.8;
    max-width: 640px;
    margin-bottom: 32px;
  }
  .podcast-platforms {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .platform-link {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--black);
    color: var(--white);
    padding: 12px 24px;
    font-size: 0.85rem; font-weight: 500;
    letter-spacing: 1px;
    border-radius: 4px;
    transition: all 0.3s var(--ease-out);
  }
  .platform-link:hover { background: var(--red); transform: translateY(-1px); }
  .podcast-embed { max-width: 800px; }

  .social-section {
    background: var(--black);
    padding: clamp(80px, 10vw, 120px) 0;
  }
  .social-section .section-tag { color: var(--red); }
  .social-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--white);
    letter-spacing: 1px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }
  .social-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .social-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 24px;
    color: var(--white);
    transition: all 0.3s var(--ease-out);
  }
  .social-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(200,16,46,0.2);
    transform: translateY(-2px);
  }
  .social-card-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .social-card-handle {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    font-weight: 300;
  }
  .social-card-arrow {
    margin-left: auto;
    color: rgba(255,255,255,0.2);
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .social-card:hover .social-card-arrow {
    color: var(--red);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .podcast-platforms { gap: 8px; }
    .social-grid { grid-template-columns: 1fr; }
  }
</style>
