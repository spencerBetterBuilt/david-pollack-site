---
import BaseLayout from '../layouts/BaseLayout.astro';
import topics from '../data/speakingTopics.json';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "David Pollack — Keynote Speaking",
  "provider": { "@type": "Person", "name": "David Pollack" },
  "serviceType": "Keynote Speaking",
  "url": "https://davidpollack.com/speaking/",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Speaking Topics",
    "itemListElement": topics.map((t, i) => ({
      "@type": "Offer",
      "position": i + 1,
      "name": t.title,
      "description": t.description
    }))
  }
};
---

<BaseLayout
  title="David Pollack — Keynote Speaker & Event Emcee"
  description="Book David Pollack for your next keynote, corporate event, faith-based gathering, or gala. Six signature topics. Custom messaging. Audiences never forget him."
  canonicalUrl="https://davidpollack.com/speaking/"
  schema={schema}
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-grid" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-content">
        <div class="section-tag">Speaking</div>
        <h1 class="page-hero-title">A SPEAKER<br>AUDIENCES<br><span>NEVER FORGET</span></h1>
        <p class="page-hero-subtitle">
          David brings the same intensity he played with — distilled into a message your audience will carry long after the event ends.
        </p>
        <a href="#inquiry" class="btn-primary" style="margin-top: 32px;">
          Inquire About Booking
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section class="credentials-section">
    <div class="container">
      <div class="credentials-grid">
        {[
          { icon: "🏆", label: "College Football Hall of Fame" },
          { icon: "⭐", label: "3x All-American, UGA" },
          { icon: "📺", label: "12 Years at ESPN" },
          { icon: "🏅", label: "7-Time Emmy Winner" },
          { icon: "🎤", label: "500+ Speaking Events" },
          { icon: "📖", label: "Author, Every Day Counts" },
        ].map(item => (
          <div class="credential-item">
            <span class="credential-icon" aria-hidden="true">{item.icon}</span>
            <span class="credential-label">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY DAVID -->
  <section class="why-section">
    <div class="container">
      <div class="why-inner">
        <div>
          <div class="section-tag reveal">Why David</div>
          <h2 class="why-title reveal reveal-delay-1">WHY AUDIENCES CONNECT WITH DAVID</h2>
        </div>
        <div class="why-text">
          <p class="why-body reveal reveal-delay-2">
            David Pollack isn't a motivational speaker who memorized a script. He's someone who has lived through the highest highs and most gut-wrenching lows — and come out the other side with something real to say. From three-time All-American to career-ending injury to 12 years in front of a national television audience, his credibility walks in the room before he does.
          </p>
          <p class="why-body reveal reveal-delay-2">
            Every speech is custom-crafted for the audience. Whether he's firing up a corporate sales team, speaking at a faith-based event, or emceeing a gala, David reads the room and delivers something memorable. His combination of energy, authenticity, humor, and purpose is rare — and rooms feel it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SPEAKING TOPICS -->
  <section class="topics-section">
    <div class="container">
      <div class="topics-header">
        <div class="section-tag reveal">Topics</div>
        <h2 class="topics-title reveal reveal-delay-1">SIGNATURE KEYNOTE TOPICS</h2>
        <p class="topics-desc reveal reveal-delay-2">Every presentation is tailored to your audience and objectives. These topics are David's starting point — not his ceiling.</p>
      </div>
      <div class="topics-grid">
        {topics.map((topic, i) => (
          <div class={`topic-card reveal reveal-delay-${Math.min(i, 4)}`}>
            <div class="topic-number">{topic.number}</div>
            <h3>{topic.title}</h3>
            <p>{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section class="inquiry-section" id="inquiry">
    <div class="container">
      <div class="inquiry-grid">
        <div class="inquiry-info">
          <div class="section-tag reveal">Book David</div>
          <h2 class="inquiry-title reveal reveal-delay-1">LET'S TALK<br>ABOUT YOUR EVENT</h2>
          <p class="inquiry-desc reveal reveal-delay-2">
            Fill out the form and David's team will be in touch within 48 hours. Every speech is custom — give us as much detail as you can.
          </p>
          <div class="inquiry-details reveal reveal-delay-3">
            <div class="inquiry-detail">
              <div class="inquiry-detail-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="inquiry-detail-label">Email</div>
                <div class="inquiry-detail-value">
                  <a href="mailto:speaking@davidpollack.com">speaking@davidpollack.com</a>
                </div>
              </div>
            </div>
            <div class="inquiry-detail">
              <div class="inquiry-detail-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <div class="inquiry-detail-label">Response Time</div>
                <div class="inquiry-detail-value">Within 48 business hours</div>
              </div>
            </div>
          </div>
        </div>

        <div class="inquiry-form-card reveal">
          <div id="formContainer">
            <h3 class="form-title">SPEAKING INQUIRY</h3>
            <p class="form-subtitle">Tell us about your event and we'll be in touch.</p>
            <form id="speakingForm" novalidate>
              <div class="form-row">
                <div class="form-group">
                  <label for="firstName">First Name *</label>
                  <input type="text" id="firstName" name="firstName" required placeholder="First name" autocomplete="given-name" />
                </div>
                <div class="form-group">
                  <label for="lastName">Last Name *</label>
                  <input type="text" id="lastName" name="lastName" required placeholder="Last name" autocomplete="family-name" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required placeholder="you@company.com" autocomplete="email" />
                </div>
                <div class="form-group">
                  <label for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" autocomplete="tel" />
                </div>
              </div>
              <div class="form-group">
                <label for="organization">Organization</label>
                <input type="text" id="organization" name="organization" placeholder="Your company or organization" autocomplete="organization" />
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="eventDate">Event Date</label>
                  <input type="date" id="eventDate" name="eventDate" />
                </div>
                <div class="form-group">
                  <label for="eventType">Event Type</label>
                  <select id="eventType" name="eventType">
                    <option value="" disabled selected>Select event type</option>
                    <option value="corporate">Corporate Keynote</option>
                    <option value="conference">Conference / Convention</option>
                    <option value="faith">Faith-Based Event</option>
                    <option value="charity">Charity / Nonprofit</option>
                    <option value="sports">Sports Event / Banquet</option>
                    <option value="emcee">Emcee / Host</option>
                    <option value="media">Media / Press Inquiry</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label for="message">Tell Us About Your Event</label>
                <textarea id="message" name="message" rows="4" placeholder="Date, location, audience size, theme — the more detail the better."></textarea>
              </div>
              <!-- Honeypot -->
              <div class="form-hp" aria-hidden="true" tabindex="-1">
                <label for="hp-website">Website</label>
                <input type="text" id="hp-website" name="website" autocomplete="off" tabindex="-1" />
              </div>
              <div class="form-hp" aria-hidden="true" tabindex="-1">
                <label for="hp-url">URL</label>
                <input type="url" id="hp-url" name="company_url" autocomplete="off" tabindex="-1" />
              </div>
              <button type="submit" class="form-submit">Send Inquiry →</button>
              <p class="form-note">We typically respond within 48 business hours.</p>
            </form>
          </div>
          <div class="form-success" id="formSuccess">
            <div class="form-success-icon" aria-hidden="true">✓</div>
            <h3>INQUIRY RECEIVED</h3>
            <p>Thank you for reaching out. David's team will be in touch soon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    background: var(--black);
    padding: clamp(140px, 15vw, 180px) 0 clamp(80px, 8vw, 100px);
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 60% 40%, rgba(200,16,46,0.12) 0%, transparent 55%),
      linear-gradient(135deg, var(--black) 0%, var(--charcoal) 100%);
  }
  .page-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .page-hero-content { position: relative; z-index: 2; }
  .page-hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  .page-hero-title span { color: var(--red); }
  .page-hero-subtitle {
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 520px;
  }

  .credentials-section {
    background: var(--red);
    padding: 20px 0;
  }
  .credentials-grid {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .credential-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 2px;
    color: var(--white);
    text-transform: uppercase;
  }
  .credential-icon { font-size: 1rem; }

  .why-section {
    padding: clamp(80px, 10vw, 120px) 0;
  }
  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .why-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 3.5vw, 3.2rem);
    letter-spacing: 1px;
    line-height: 1;
    margin-bottom: 0;
  }
  .why-body {
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    line-height: 1.85;
    color: #555;
    font-weight: 300;
    margin-bottom: 20px;
  }

  .topics-section {
    background: var(--black);
    padding: clamp(80px, 10vw, 120px) 0;
    position: relative;
    overflow: hidden;
  }
  .topics-section::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(200,16,46,0.06) 0%, transparent 50%);
  }
  .topics-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(40px, 5vw, 64px);
    position: relative;
  }
  .topics-header .section-tag { display: inline-flex; }
  .topics-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--white);
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  .topics-desc {
    color: rgba(255,255,255,0.5);
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    font-weight: 300;
    line-height: 1.7;
  }
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 1.5vw, 24px);
    position: relative;
  }
  .topic-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: clamp(24px, 2.5vw, 40px) clamp(20px, 2vw, 32px);
    transition: all 0.4s var(--ease-out);
    position: relative;
    overflow: hidden;
  }
  .topic-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 100%; height: 3px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }
  .topic-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(200,16,46,0.2); transform: translateY(-4px); }
  .topic-card:hover::before { transform: scaleX(1); }
  .topic-number {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(200,16,46,0.15);
    line-height: 1;
    margin-bottom: 16px;
  }
  .topic-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    color: var(--white);
    letter-spacing: 1px;
    margin-bottom: 12px;
  }
  .topic-card p {
    font-size: clamp(0.82rem, 0.9vw, 0.9rem);
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    font-weight: 300;
  }

  .inquiry-section {
    padding: clamp(80px, 10vw, 120px) 0;
  }
  .inquiry-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }
  .inquiry-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 3.5vw, 3.2rem);
    line-height: 1;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }
  .inquiry-desc {
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    color: #555;
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: 40px;
  }
  .inquiry-details { display: flex; flex-direction: column; gap: 20px; }
  .inquiry-detail { display: flex; align-items: center; gap: 16px; }
  .inquiry-detail-icon {
    width: 48px; height: 48px;
    background: var(--red);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: white;
  }
  .inquiry-detail-label {
    font-size: 0.72rem;
    color: var(--mid-gray);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .inquiry-detail-value { font-size: 1rem; font-weight: 500; color: var(--black); }
  .inquiry-detail-value a { color: var(--red); }
  .inquiry-detail-value a:hover { text-decoration: underline; }

  .inquiry-form-card {
    background: var(--white);
    border-radius: var(--radius-form-card);
    padding: clamp(32px, 4vw, 48px);
    box-shadow: 0 4px 40px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.04);
  }
  .form-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .form-subtitle {
    font-size: 0.9rem;
    color: var(--mid-gray);
    margin-bottom: 32px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 0;
  }
  .form-note {
    font-size: 0.75rem;
    color: var(--mid-gray);
    text-align: center;
    margin-top: 16px;
  }
  .form-success {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }
  .form-success.show { display: block; }
  .form-success-icon {
    width: 64px; height: 64px;
    background: rgba(200,16,46,0.08);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    font-size: 1.5rem;
    color: var(--red);
  }
  .form-success h3 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    margin-bottom: 8px;
  }
  .form-success p { color: var(--mid-gray); font-size: 0.95rem; }

  @media (max-width: 1024px) {
    .why-inner { grid-template-columns: 1fr; gap: 40px; }
    .topics-grid { grid-template-columns: 1fr 1fr; }
    .inquiry-grid { grid-template-columns: 1fr; gap: 60px; }
  }
  @media (max-width: 768px) {
    .credentials-grid { gap: 12px; }
    .credential-item { font-size: 0.72rem; }
    .topics-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('speakingForm') as HTMLFormElement;
  const formContainer = document.getElementById('formContainer');
  const formSuccess = document.getElementById('formSuccess');
  const loadTime = Date.now();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    // Honeypot checks
    if (data.get('website') || data.get('company_url')) return;
    // Timing check
    if (Date.now() - loadTime < 3000) return;

    // TODO: POST to HubSpot Forms API
    // POST https://api.hsforms.com/submissions/v3/integration/submit/{portalId}/{formGuid}
    // Body: { fields: [...], context: { pageUri, pageName } }
    console.log('Speaking inquiry:', Object.fromEntries(data));

    if (formContainer && formSuccess) {
      formContainer.querySelector('form')!.style.display = 'none';
      formSuccess.classList.add('show');
    }
  });
</script>
